#!/usr/bin/env bash
# Pre-push hook: keep apps/web/src/api/schema.d.ts in sync with backend handlers.
#
# If any backend handler (or main.go, which carries swag annotations) has been
# modified more recently than apps/web/src/api/schema.d.ts, regenerate the
# schema, stage it, and abort the push so the user can review the diff before
# committing.
#
# Uses pure git plumbing (no `stat`, no `find -print0`) so it works the same
# on Linux, macOS, Git Bash on Windows, and WSL.
#
# Enable with: git config core.hooksPath .githooks

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Paths whose content influences the generated OpenAPI schema.
tracked=(
  "backend/internal/api/handlers"
  "backend/cmd/server/main.go"
)
schema="apps/web/src/api/schema.d.ts"

# --- decision: does the schema need regenerating? --------------------------
needs_regen=0

# Case 1: schema is missing or not tracked by git. Without a tracked
# baseline we can't prove the schema is in sync — regenerate to be safe.
if [ ! -f "$repo_root/$schema" ] \
   || ! git -C "$repo_root" ls-files --error-unmatch -- "$schema" >/dev/null 2>&1; then
  needs_regen=1
fi

# Case 2: working tree (staged or unstaged) has uncommitted changes in any
# tracked path. `git diff HEAD` covers both kinds of modifications.
if [ "$needs_regen" -eq 0 ] \
   && ! git -C "$repo_root" diff --quiet HEAD -- "${tracked[@]}" 2>/dev/null; then
  needs_regen=1
fi

# Case 3: committed handler change is newer than the latest schema commit.
# (Only meaningful when both have git history.)
if [ "$needs_regen" -eq 0 ]; then
  schema_commit=$(git -C "$repo_root" log -1 --format=%H -- "$schema" 2>/dev/null || true)
  latest_commit=$(git -C "$repo_root" log -1 --format=%H -- "${tracked[@]}" 2>/dev/null || true)
  if [ -z "$schema_commit" ] || [ -z "$latest_commit" ]; then
    needs_regen=1
  elif ! git -C "$repo_root" merge-base --is-ancestor "$latest_commit" "$schema_commit" 2>/dev/null; then
    needs_regen=1
  fi
fi

if [ "$needs_regen" -eq 0 ]; then
  exit 0
fi

# --- snapshot pre-regen content -------------------------------------------
# Used after regen to detect a no-op (file content didn't actually change).
if [ -f "$repo_root/$schema" ]; then
  schema_before=$(sha256sum "$repo_root/$schema" 2>/dev/null | awk '{print $1}')
else
  schema_before=""
fi

# --- regenerate -----------------------------------------------------------
echo "pre-push: regenerating schema.d.ts..." >&2

(
  cd "$repo_root"
  (cd backend && go run github.com/swaggo/swag/cmd/swag@v1.16.6 init \
    -g cmd/server/main.go -o internal/docs --parseDependency --parseInternal) >&2
  (cd apps/web && pnpm gen:api) >&2
)

# --- verify: did the regen actually change anything? ----------------------
schema_after=$(sha256sum "$repo_root/$schema" 2>/dev/null | awk '{print $1}')
if [ "$schema_before" = "$schema_after" ]; then
  # No content change — was a false alarm, don't bother the user.
  exit 0
fi

# Real drift (or schema was missing/untracked). Stage for the user to review.
git -C "$repo_root" add -f "$schema"

cat >&2 <<'EOF'
pre-push: schema.d.ts has been regenerated and staged (not committed).

Review the diff with:  git diff --cached apps/web/src/api/schema.d.ts
If the change is expected, commit it (e.g. git commit --amend or a new commit)
and re-run:  git push
EOF
exit 1